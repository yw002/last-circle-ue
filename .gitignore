# Unreal Engine 5 - Standard .gitignore
# Based on Epic Games' recommended .gitignore for UE5 projects

# Visual Studio / Rider
.vs/
*.sln
*.slnx
*.suo
*.VC.db
*.VC.opendb
*.ipch

# Visual Studio Code
.vscode/

# Project files generated by UBT
Makefile
CMakeLists.txt
*.make
*.cmake
*.xcodeproj
*.xcworkspace

# Binaries
Binaries/

# Intermediate build files
Intermediate/

# Saved (config, logs, autosaves, crash reports, screenshots)
Saved/

# DerivedDataCache
DerivedDataCache/

# Backup
Backup/

# Engine association
*.uprojectdirs

# Pak files
*.pak
*.ucas
*.utoc

# Shader cache
*.ushaderbytecode

# Compiled Shader format
*.shaderbin

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Linux
*~

# Build scripts (user-specific)
BuildEditor.bat
GenerateProjectFiles.bat

# Automation tool
AutomationTool/

# Auto-generated by UE
UE5_REBUILD_PROMPT.md
UpgradeLog.htm
build_out.txt
build_out2.txt
build_err.txt
build_log.txt
